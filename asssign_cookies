greed=[1,3,5,6,2,3]
size=[3,2,1,1,2,4]
n1=len(greed)
n2=len(size)
greed.sort()
size.sort()
print(greed)
print(size)

left=0
right=0
count=0
while right<n1 and left<n2:
    if size[left]>=greed[right]:
        count=count+1
        right+=1
        left+=1
       
    else:
        left+=1
print(count)

'''Final Time Complexity: O(n1 log n1 + n2 log n2)




Space = O(n1 + n2) (in worst case)

Case 2: If sorting is in-place (theoretical)

Space = O(1)'''
