nums=[1,0,1,0,1,1,0,0,1]
right=0
left=0
zeros=0
max_length=0
k=2
n=len(nums)
while right<n:
    if nums[right]==0:
        zeros+=1
    while zeros>k:
        if nums[left]==0:
           zeros-=1
        left+=1
    if zeros<=k:
        max_length=max(max_length,right-left+1)
    right+=1
print(max_length)

