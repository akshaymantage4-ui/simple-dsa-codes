s=('c','a','d','b','z','a','b','c','d')
n=len(s)
my_dict={}
left=0
right=0
maxi=0

while right<n:
    if s[right] in my_dict:
        left=max(left,my_dict[s[right]]+1)
        
    maxi=max(maxi,right-left+1)
    my_dict[s[right]]=right
    right+=1
    
print(maxi)


#if i use s like s=('c,a,d,b,z,a,b,c,d')then , are also considered characters

#time complexity=o(n)
